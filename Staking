pragma solidity 0.8.34;

import "@openzeppelin/contracts@5.1.0/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts@5.1.0/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts@5.1.0/access/Ownable2Step.sol";
import "@openzeppelin/contracts@5.1.0/utils/Pausable.sol";
import "@openzeppelin/contracts@5.1.0/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts@5.1.0/utils/math/Math.sol";

/// @title BeeFi MEL Staking
/// @author BeeFi
/// @notice Two-vault MEL staking contract with fixed flexible staking, participation-based variable staking, circulating-supply snapshots, and delayed withdrawals.
/// @dev
/// Design overview:
/// - Two vaults are supported: Flexible and Variable.
/// - Flexible vault uses a fixed 2.50% APR with request -> delay -> claim withdrawals.
/// - Variable vault uses a stake-time locked APR derived from cached circulating supply snapshots, with a mandatory 51-day lock.
/// - One active stake per user per vault is allowed.
/// - Rewards are paid only from the MEL reward pool explicitly funded into this contract.
/// - Variable-vault APR depends on `variableVaultTotalStaked / cachedCirculatingSupply`.
/// - Circulating supply is refreshed manually through `refreshCirculatingSupply()` and used as a daily-style snapshot.
/// - Early exit before the 51-day variable lock is only available through `emergencyWithdraw()` with zero rewards.
/// - Arithmetic intentionally rounds down in favor of contract solvency.
contract MELStaking is Ownable2Step, Pausable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    // =============================================================
    //                           CONSTANTS
    // =============================================================

    /// @notice MEL token used for staking principal and reward payments.
    IERC20 public immutable stakingToken;

    /// @dev Flexible vault identifier.
    uint256 private constant _VAULT_FLEXIBLE = 0;

    /// @dev Variable vault identifier.
    uint256 private constant _VAULT_VARIABLE = 1;

    /// @dev Number of supported vaults.
    uint256 private constant _VAULT_COUNT = 2;

    /// @dev Basis-point divisor.
    uint256 private constant _BPS = 10_000;

    /// @dev Number of seconds in one accounting year.
    uint256 private constant _SECONDS_IN_YEAR = 365 days;

    /// @dev Minimum per-stake deposit amount.
    uint256 private constant _MIN_DEPOSIT = 2_000 * 1e18;

    /// @dev Maximum per-stake deposit amount.
    uint256 private constant _MAX_DEPOSIT = 5_000_000 * 1e18;

    /// @dev Maximum number of addresses tracked in the circulation exclusion list.
    ///      This bound is intentional to keep refresh gas predictable and avoid unbounded-array warnings.
    uint256 private constant _MAX_EXCLUDED_ADDRESSES = 32;

    /// @dev Flexible vault fixed APR: 2.50%.
    uint16 private constant _FLEXIBLE_APR_BPS = 250;

    /// @dev Variable vault minimum APR: 4.00%.
    uint16 private constant _VARIABLE_MIN_APR_BPS = 400;

    /// @dev Variable vault maximum APR: 14.00%.
    uint16 private constant _VARIABLE_MAX_APR_BPS = 1400;

    /// @dev Variable vault mandatory lock period.
    uint40 private constant _VARIABLE_LOCK_PERIOD = 51 days;

    /// @dev Delay between withdrawal request and claim.
    uint40 private constant _WITHDRAW_DELAY = 24 hours;

    /// @dev Minimum interval between circulating-supply refreshes.
    uint40 private constant _REFRESH_COOLDOWN = 24 hours;

    /// @dev Maximum allowed age for the circulating-supply snapshot used by variable staking.
    uint40 private constant _MAX_SNAPSHOT_AGE = 48 hours;

    // =============================================================
    //                             ERRORS
    // =============================================================

    error InvalidTokenAddress();
    error InvalidVaultId();
    error VaultInactive();
    error ZeroAmount();
    error AmountBelowMinimum(uint256 minimum);
    error AmountAboveMaximum(uint256 maximum);
    error AlreadyStaked();
    error NoActiveStake();
    error WithdrawalAlreadyRequested();
    error WithdrawalNotRequested();
    error LockNotCompleted(uint256 unlockAt);
    error WaitPeriodNotOver(uint256 claimableAt);
    error SnapshotNotReady();
    error SnapshotStale(uint256 lastRefreshTime);
    error RefreshTooSoon(uint256 nextRefreshTime);
    error InvalidExcludedAddress();
    error AddressAlreadyExcluded();
    error AddressNotExcluded();
    error UnsupportedTokenBehavior();
    error InsufficientPrincipalLiquidity();
    error InsufficientRewardReserve(uint256 requiredRewards, uint256 availableRewards);
    error ActiveWithdrawalRequest();
    error EmergencyExitUnavailable();
    error ExcludedAddressLimitReached(uint256 maxAllowed);

    // =============================================================
    //                            STORAGE
    // =============================================================

    /// @dev Vault configuration record.
    struct VaultConfig {
        uint16 aprBps;
        uint40 minLockPeriod;
        bool active;
    }

    /// @dev Per-user stake position. One active position per user per vault.
    struct StakePosition {
        uint128 amount;
        uint40 startTime;
        uint40 rewardStopTime;
        uint40 requestTime;
        uint40 claimableAt;
        uint16 lockedAprBps;
    }

    /// @notice Configuration for each supported vault.
    VaultConfig[_VAULT_COUNT] public vaults;

    /// @dev User positions indexed by user and vault id.
    mapping(address account => mapping(uint256 vaultId => StakePosition)) private _stakes;

    /// @notice Total principal currently staked across all vaults.
    uint256 public totalPrincipalStaked;

    /// @notice Total principal currently staked in the flexible vault.
    uint256 public flexibleVaultTotalStaked;

    /// @notice Total principal currently staked in the variable vault.
    uint256 public variableVaultTotalStaked;

    /// @notice Total MEL reward tokens explicitly funded by the owner and not yet paid out.
    uint256 public rewardPoolBalance;

    /// @notice Last cached total of excluded balances used for circulating-supply calculation.
    uint256 public cachedExcludedSupply;

    /// @notice Last cached circulating supply used for variable-vault APR calculation.
    uint256 public cachedCirculatingSupply;

    /// @notice Timestamp of the most recent circulating-supply refresh.
    uint256 public lastRefreshTime;

    /// @notice Returns whether an address is excluded from circulating-supply calculation.
    mapping(address account => bool isExcluded) public isExcludedFromCirculation;

    /// @dev 1-based index mapping used for O(1) excluded-address removal.
    mapping(address account => uint256 indexPlusOne) private _excludedIndexPlusOne;

    /// @dev Enumerable list of excluded addresses.
    address[] private _excludedAddresses;

    // =============================================================
    //                            EVENTS
    // =============================================================

    /// @notice Emitted when a user stakes into a vault.
    /// @param user Address of the staker.
    /// @param vaultId Target vault id.
    /// @param amount Staked principal amount.
    /// @param aprBps APR locked at entry in basis points.
    event Staked(address indexed user, uint256 indexed vaultId, uint256 amount, uint256 aprBps);

    /// @notice Emitted when a withdrawal request is created.
    /// @param user Address of the staker.
    /// @param vaultId Target vault id.
    /// @param requestTime Timestamp when the request was submitted.
    /// @param claimableAt Timestamp when the withdrawal becomes claimable.
    event WithdrawalRequested(address indexed user, uint256 indexed vaultId, uint256 requestTime, uint256 claimableAt);

    /// @notice Emitted when principal and rewards are claimed.
    /// @param user Address of the staker.
    /// @param vaultId Target vault id.
    /// @param principal Principal returned.
    /// @param rewards Reward amount paid.
    event Claimed(address indexed user, uint256 indexed vaultId, uint256 principal, uint256 rewards);

    /// @notice Emitted when a variable-vault position exits early without rewards.
    /// @param user Address of the staker.
    /// @param vaultId Target vault id.
    /// @param principal Principal returned.
    event EmergencyWithdrawn(address indexed user, uint256 indexed vaultId, uint256 principal);

    /// @notice Emitted when the owner deposits MEL reward tokens into the contract.
    /// @param depositor Address performing the deposit.
    /// @param amount Amount deposited.
    /// @param newRewardPoolBalance New tracked reward pool balance.
    event RewardDeposited(address indexed depositor, uint256 amount, uint256 newRewardPoolBalance);

    /// @notice Emitted when a vault's active status is updated.
    /// @param vaultId Vault identifier.
    /// @param isActive New active state.
    event VaultStatusUpdated(uint256 indexed vaultId, bool isActive);

    /// @notice Emitted when an address is added to the circulation exclusion list.
    /// @param account Excluded address.
    event ExcludedAddressAdded(address indexed account);

    /// @notice Emitted when an address is removed from the circulation exclusion list.
    /// @param account Removed address.
    event ExcludedAddressRemoved(address indexed account);

    /// @notice Emitted when circulating supply is refreshed.
    /// @param excludedSupply Total excluded balance at refresh time.
    /// @param circulatingSupply Resulting circulating supply snapshot.
    /// @param refreshedAt Refresh timestamp.
    event CirculatingSupplyRefreshed(uint256 excludedSupply, uint256 circulatingSupply, uint256 refreshedAt);

    // =============================================================
    //                          CONSTRUCTOR
    // =============================================================

    /// @notice Deploys the staking contract and initializes both vault configurations.
    /// @param stakingToken_ MEL token address used for principal and rewards.
    constructor(address stakingToken_) Ownable(msg.sender) {
        if (stakingToken_ == address(0)) revert InvalidTokenAddress();

        stakingToken = IERC20(stakingToken_);

        vaults[_VAULT_FLEXIBLE] = VaultConfig({
            aprBps: _FLEXIBLE_APR_BPS,
            minLockPeriod: 0,
            active: true
        });

        vaults[_VAULT_VARIABLE] = VaultConfig({
            aprBps: 0,
            minLockPeriod: _VARIABLE_LOCK_PERIOD,
            active: true
        });
    }

    // =============================================================
    //                       CORE FUNCTIONS
    // =============================================================

    /// @notice Stakes MEL into the selected vault.
    /// @dev
    /// Requirements:
    /// - vault must be valid and active
    /// - `amount` must be within the configured min / max deposit bounds
    /// - caller must not already have an active position in the same vault
    /// - variable-vault staking requires a fresh circulating-supply snapshot
    /// - token transfer must satisfy `received == amount`
    ///
    /// @param vaultId Vault identifier.
    /// @param amount MEL amount to stake.
    function stake(uint256 vaultId, uint256 amount) external nonReentrant whenNotPaused {
        if (vaultId >= _VAULT_COUNT) revert InvalidVaultId();
        if (!vaults[vaultId].active) revert VaultInactive();
        if (amount == 0) revert ZeroAmount();
        if (amount < _MIN_DEPOSIT) revert AmountBelowMinimum(_MIN_DEPOSIT);
        if (amount > _MAX_DEPOSIT) revert AmountAboveMaximum(_MAX_DEPOSIT);

        StakePosition storage position = _stakes[msg.sender][vaultId];
        if (position.amount != 0) revert AlreadyStaked();

        uint16 aprBps;
        if (vaultId == _VAULT_FLEXIBLE) {
            aprBps = _FLEXIBLE_APR_BPS;
        } else {
            _requireFreshSnapshot();
            aprBps = _currentVariableAprBps();
        }

        uint256 balanceBefore = stakingToken.balanceOf(address(this));
        stakingToken.safeTransferFrom(msg.sender, address(this), amount);
        uint256 received = stakingToken.balanceOf(address(this)) - balanceBefore;
        if (received != amount) revert UnsupportedTokenBehavior();

        uint40 currentTimestamp = uint40(block.timestamp);

        position.amount = uint128(amount);
        position.startTime = currentTimestamp;
        position.rewardStopTime = 0;
        position.requestTime = 0;
        position.claimableAt = 0;
        position.lockedAprBps = aprBps;

        totalPrincipalStaked += amount;

        if (vaultId == _VAULT_FLEXIBLE) {
            flexibleVaultTotalStaked += amount;
        } else {
            variableVaultTotalStaked += amount;
        }

        emit Staked(msg.sender, vaultId, amount, aprBps);
    }

    /// @notice Requests a normal withdrawal for an active stake.
    /// @dev
    /// Requirements:
    /// - caller must have an active position in the selected vault
    /// - no withdrawal request may already exist
    /// - variable-vault positions may request normal withdrawal only after the 51-day lock
    ///
    /// @param vaultId Vault identifier.
    function requestWithdrawal(uint256 vaultId) external nonReentrant {
        if (vaultId >= _VAULT_COUNT) revert InvalidVaultId();

        StakePosition storage position = _stakes[msg.sender][vaultId];
        if (position.amount == 0) revert NoActiveStake();
        if (position.claimableAt != 0) revert WithdrawalAlreadyRequested();

        uint40 currentTimestamp = uint40(block.timestamp);

        if (vaultId == _VAULT_VARIABLE) {
            uint256 unlockAt = uint256(position.startTime) + uint256(_VARIABLE_LOCK_PERIOD);
            if (block.timestamp < unlockAt) revert LockNotCompleted(unlockAt);
        }

        position.rewardStopTime = currentTimestamp;
        position.requestTime = currentTimestamp;
        position.claimableAt = currentTimestamp + _WITHDRAW_DELAY;

        emit WithdrawalRequested(msg.sender, vaultId, currentTimestamp, position.claimableAt);
    }

    /// @notice Claims principal plus accrued rewards after a withdrawal request matures.
    /// @param vaultId Vault identifier.
    function claimWithdrawal(uint256 vaultId) external nonReentrant {
        if (vaultId >= _VAULT_COUNT) revert InvalidVaultId();

        StakePosition storage position = _stakes[msg.sender][vaultId];
        uint256 principal = uint256(position.amount);
        if (principal == 0) revert NoActiveStake();
        if (position.claimableAt == 0) revert WithdrawalNotRequested();
        if (block.timestamp < uint256(position.claimableAt)) revert WaitPeriodNotOver(position.claimableAt);

        uint256 rewardDuration = uint256(position.rewardStopTime) - uint256(position.startTime);
        uint256 rewards = _calculateRewards(principal, position.lockedAprBps, rewardDuration);

        uint256 contractBalance = stakingToken.balanceOf(address(this));
        if (contractBalance < principal) revert InsufficientPrincipalLiquidity();

        uint256 rewardReserve = _rewardReserve(contractBalance);
        if (rewardReserve < rewards) {
            revert InsufficientRewardReserve(rewards, rewardReserve);
        }

        totalPrincipalStaked -= principal;
        rewardPoolBalance -= rewards;

        if (vaultId == _VAULT_FLEXIBLE) {
            flexibleVaultTotalStaked -= principal;
        } else {
            variableVaultTotalStaked -= principal;
        }

        delete _stakes[msg.sender][vaultId];

        stakingToken.safeTransfer(msg.sender, principal + rewards);

        emit Claimed(msg.sender, vaultId, principal, rewards);
    }

    /// @notice Executes an emergency early exit for the variable vault before the 51-day lock ends.
    /// @dev Rewards are fully forfeited.
    /// @param vaultId Vault identifier. Must be the variable vault.
    function emergencyWithdraw(uint256 vaultId) external nonReentrant {
        if (vaultId != _VAULT_VARIABLE) revert EmergencyExitUnavailable();

        StakePosition storage position = _stakes[msg.sender][vaultId];
        uint256 principal = uint256(position.amount);
        if (principal == 0) revert NoActiveStake();
        if (position.claimableAt != 0) revert ActiveWithdrawalRequest();

        uint256 unlockAt = uint256(position.startTime) + uint256(_VARIABLE_LOCK_PERIOD);
        if (block.timestamp >= unlockAt) revert EmergencyExitUnavailable();

        uint256 contractBalance = stakingToken.balanceOf(address(this));
        if (contractBalance < principal) revert InsufficientPrincipalLiquidity();

        totalPrincipalStaked -= principal;
        variableVaultTotalStaked -= principal;

        delete _stakes[msg.sender][vaultId];

        stakingToken.safeTransfer(msg.sender, principal);

        emit EmergencyWithdrawn(msg.sender, vaultId, principal);
    }

    // =============================================================
    //                      VIEW FUNCTIONS
    // =============================================================

    /// @notice Returns the configured min / max deposit bounds.
    function getDepositBounds() external pure returns (uint256 minDeposit, uint256 maxDeposit) {
        return (_MIN_DEPOSIT, _MAX_DEPOSIT);
    }

    /// @notice Returns the current locked position data for a user and vault.
    /// @param account Address to inspect.
    /// @param vaultId Vault identifier.
    /// @return amount Principal amount.
    /// @return startTime Position start timestamp.
    /// @return rewardStopTime Reward accrual stop timestamp. Zero if not requested yet.
    /// @return requestTime Withdrawal request timestamp. Zero if not requested yet.
    /// @return claimableAt Claim-eligible timestamp. Zero if not requested yet.
    /// @return lockedAprBps APR locked at entry in basis points.
    /// @return pendingRewards Rewards accrued so far under the locked APR.
    function getStakeInfo(address account, uint256 vaultId)
        external
        view
        returns (
            uint256 amount,
            uint256 startTime,
            uint256 rewardStopTime,
            uint256 requestTime,
            uint256 claimableAt,
            uint256 lockedAprBps,
            uint256 pendingRewards
        )
    {
        if (vaultId >= _VAULT_COUNT) revert InvalidVaultId();

        StakePosition memory position = _stakes[account][vaultId];
        amount = uint256(position.amount);
        startTime = uint256(position.startTime);
        rewardStopTime = uint256(position.rewardStopTime);
        requestTime = uint256(position.requestTime);
        claimableAt = uint256(position.claimableAt);
        lockedAprBps = uint256(position.lockedAprBps);

        if (amount == 0) {
            return (amount, startTime, rewardStopTime, requestTime, claimableAt, lockedAprBps, 0);
        }

        uint256 effectiveStop = rewardStopTime;
        if (effectiveStop == 0) {
            effectiveStop = block.timestamp;
        }

        if (effectiveStop < startTime) {
            return (amount, startTime, rewardStopTime, requestTime, claimableAt, lockedAprBps, 0);
        }

        pendingRewards = _calculateRewards(amount, position.lockedAprBps, effectiveStop - startTime);
    }

    /// @notice Returns the current variable-vault APR preview based on the latest cached circulating supply.
    function previewVariableAprBps() external view returns (uint256) {
        _requireFreshSnapshot();
        return _currentVariableAprBps();
    }

    /// @notice Returns the current variable-vault participation rate in basis points.
    function getCurrentParticipationRateBps() external view returns (uint256) {
        _requireFreshSnapshot();
        return _currentParticipationRateBps();
    }

    /// @notice Returns the currently available reward reserve.
    function getRewardReserve() external view returns (uint256) {
        return _rewardReserve(stakingToken.balanceOf(address(this)));
    }

    /// @notice Returns the full excluded-address list used for circulating-supply calculation.
    function getExcludedAddresses() external view returns (address[] memory) {
        return _excludedAddresses;
    }

    // =============================================================
    //                      ADMIN & SECURITY
    // =============================================================

    /// @notice Deposits MEL reward tokens into the staking contract.
    /// @dev Only explicitly funded reward tokens are treated as claimable rewards.
    /// @param amount Amount of MEL to deposit.
    function depositReward(uint256 amount) external onlyOwner {
        if (amount == 0) revert ZeroAmount();

        uint256 balanceBefore = stakingToken.balanceOf(address(this));
        stakingToken.safeTransferFrom(msg.sender, address(this), amount);
        uint256 received = stakingToken.balanceOf(address(this)) - balanceBefore;
        if (received != amount) revert UnsupportedTokenBehavior();

        rewardPoolBalance += amount;

        emit RewardDeposited(msg.sender, amount, rewardPoolBalance);
    }

    /// @notice Refreshes the cached excluded and circulating supply values.
    /// @dev
    /// Requirements:
    /// - may only be called by the owner
    /// - may only be called once per 24-hour cooldown window
    ///
    /// The resulting snapshot is used for subsequent variable-vault staking until the next refresh.
    function refreshCirculatingSupply() external onlyOwner {
        uint256 refreshedAt = lastRefreshTime;
        if (refreshedAt != 0 && block.timestamp < refreshedAt + _REFRESH_COOLDOWN) {
            revert RefreshTooSoon(refreshedAt + _REFRESH_COOLDOWN);
        }

        uint256 excludedSupply = 0;
        uint256 len = _excludedAddresses.length;

        for (uint256 i = 0; i < len; ) {
            excludedSupply += stakingToken.balanceOf(_excludedAddresses[i]);
            unchecked {
                ++i;
            }
        }

        uint256 totalSupply_ = stakingToken.totalSupply();
        uint256 circulatingSupply = totalSupply_ > excludedSupply ? totalSupply_ - excludedSupply : 0;

        cachedExcludedSupply = excludedSupply;
        cachedCirculatingSupply = circulatingSupply;
        lastRefreshTime = block.timestamp;

        emit CirculatingSupplyRefreshed(excludedSupply, circulatingSupply, block.timestamp);
    }

    /// @notice Adds an address to the circulating-supply exclusion list.
    /// @param account Address to exclude.
    function addExcludedAddress(address account) external onlyOwner {
        if (account == address(0)) revert InvalidExcludedAddress();
        if (isExcludedFromCirculation[account]) revert AddressAlreadyExcluded();
        if (_excludedAddresses.length >= _MAX_EXCLUDED_ADDRESSES) {
            revert ExcludedAddressLimitReached(_MAX_EXCLUDED_ADDRESSES);
        }

        isExcludedFromCirculation[account] = true;
        _excludedAddresses.push(account);
        _excludedIndexPlusOne[account] = _excludedAddresses.length;

        emit ExcludedAddressAdded(account);
    }

    /// @notice Removes an address from the circulating-supply exclusion list.
    /// @param account Address to remove.
    function removeExcludedAddress(address account) external onlyOwner {
        if (!isExcludedFromCirculation[account]) revert AddressNotExcluded();

        uint256 index = _excludedIndexPlusOne[account] - 1;
        uint256 lastIndex = _excludedAddresses.length - 1;

        if (index != lastIndex) {
            address movedAccount = _excludedAddresses[lastIndex];
            _excludedAddresses[index] = movedAccount;
            _excludedIndexPlusOne[movedAccount] = index + 1;
        }

        _excludedAddresses.pop();
        delete _excludedIndexPlusOne[account];
        delete isExcludedFromCirculation[account];

        emit ExcludedAddressRemoved(account);
    }

    /// @notice Enables or disables new deposits for a vault.
    /// @param vaultId Vault identifier.
    /// @param isActive New active state.
    function setVaultStatus(uint256 vaultId, bool isActive) external onlyOwner {
        if (vaultId >= _VAULT_COUNT) revert InvalidVaultId();
        vaults[vaultId].active = isActive;
        emit VaultStatusUpdated(vaultId, isActive);
    }

    /// @notice Pauses new staking operations.
    function pause() external onlyOwner {
        _pause();
    }

    /// @notice Unpauses new staking operations.
    function unpause() external onlyOwner {
        _unpause();
    }

    // =============================================================
    //                        INTERNAL LOGIC
    // =============================================================

    /// @dev Reverts if the variable-vault snapshot is missing or too old.
    function _requireFreshSnapshot() internal view {
        if (lastRefreshTime == 0) revert SnapshotNotReady();
        if (cachedCirculatingSupply == 0) revert SnapshotNotReady();
        if (block.timestamp > lastRefreshTime + _MAX_SNAPSHOT_AGE) {
            revert SnapshotStale(lastRefreshTime);
        }
    }

    /// @dev Returns the current variable-vault APR in basis points using a linear decrease from 14.00% to 4.00%.
    function _currentVariableAprBps() internal view returns (uint16) {
        uint256 participationRateBps = _currentParticipationRateBps();
        if (participationRateBps >= _BPS) {
            return _VARIABLE_MIN_APR_BPS;
        }

        uint256 aprSpan = uint256(_VARIABLE_MAX_APR_BPS) - uint256(_VARIABLE_MIN_APR_BPS);
        uint256 reduction = Math.mulDiv(aprSpan, participationRateBps, _BPS);
        return uint16(uint256(_VARIABLE_MAX_APR_BPS) - reduction);
    }

    /// @dev Returns variable-vault participation as `variableVaultTotalStaked / cachedCirculatingSupply` in basis points, capped at 100.00%.
    function _currentParticipationRateBps() internal view returns (uint256) {
        if (cachedCirculatingSupply == 0) {
            return _BPS;
        }

        uint256 participationRateBps = Math.mulDiv(variableVaultTotalStaked, _BPS, cachedCirculatingSupply);
        if (participationRateBps > _BPS) {
            return _BPS;
        }
        return participationRateBps;
    }

    /// @dev Returns reward amount for a given principal, APR, and elapsed duration.
    ///      Rounding down is intentional and acceptable for staking reward accounting.
    function _calculateRewards(uint256 principal, uint256 aprBps, uint256 durationSeconds) internal pure returns (uint256) {
        return Math.mulDiv(principal, uint256(aprBps) * durationSeconds, _BPS * _SECONDS_IN_YEAR);
    }

    /// @dev Returns the currently available reward reserve after excluding user principal.
    ///      The reserve is additionally capped by the explicitly funded reward pool balance.
    function _rewardReserve(uint256 contractBalance) internal view returns (uint256) {
        if (contractBalance <= totalPrincipalStaked) {
            return 0;
        }

        uint256 balanceBasedReserve = contractBalance - totalPrincipalStaked;
        if (balanceBasedReserve < rewardPoolBalance) {
            return balanceBasedReserve;
        }
        return rewardPoolBalance;
    }
}
